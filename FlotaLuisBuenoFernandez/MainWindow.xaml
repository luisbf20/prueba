<Window x:Class="FlotaLuisBuenoFernandez.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlotaLuisBuenoFernandez"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="615"
        Width="706">

    <Grid x:Name="MiGrid">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
 
        <Grid x:Name="TableroGrid"  Grid.Row="0" Grid.Column="0">

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

           
            <Button Grid.Row="0" Grid.Column="0" Click="Boton_Click" Tag="0,0" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="0" Grid.Column="1" Click="Boton_Click" Tag="0,1" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="0" Grid.Column="2" Click="Boton_Click" Tag="0,2" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="0" Grid.Column="3" Click="Boton_Click" Tag="0,3" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

         
            <Button Grid.Row="1" Grid.Column="0" Click="Boton_Click" Tag="1,0" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="1" Grid.Column="1" Click="Boton_Click" Tag="1,1" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="1" Grid.Column="2" Click="Boton_Click" Tag="1,2" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="1" Grid.Column="3" Click="Boton_Click" Tag="1,3" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

           
            <Button Grid.Row="2" Grid.Column="0" Click="Boton_Click" Tag="2,0" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="2" Grid.Column="1" Click="Boton_Click" Tag="2,1" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="2" Grid.Column="2" Click="Boton_Click" Tag="2,2" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="2" Grid.Column="3" Click="Boton_Click" Tag="2,3" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

           
            <Button Grid.Row="3" Grid.Column="0" Click="Boton_Click" Tag="3,0" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="3" Grid.Column="1" Click="Boton_Click" Tag="3,1" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="3" Grid.Column="2" Click="Boton_Click" Tag="3,2" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

            <Button Grid.Row="3" Grid.Column="3" Click="Boton_Click" Tag="3,3" Padding="0" BorderThickness="0">
                <Image Source="imagenes/agua.png" Stretch="UniformToFill"/>
            </Button>

        </Grid>

       
        <DataGrid x:Name="tablaJugadas"
                  Grid.Row="0"
                  Grid.Column="1"
                  Margin="10"/>

       
        <Button x:Name="btnReiniciar"
                Content="Reiniciar"
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Height="60"
                FontSize="20"
                Margin="10"
                Click="Reset_Click"/>

    </Grid>
</Window>